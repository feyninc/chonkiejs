CHONKIE_DOCS_URL=https://feyninc.github.io/chonkie
NEXT_PUBLIC_CHONKIE_DOCS_URL=https://feyninc.github.io/chonkie
NEXT_PUBLIC_DOCS_SITE_URL=http://localhost:3000

# chonkiejs syncs content + public assets from CHONKIE_DOCS_URL/manifest.json.
# Synced MDX image paths are rewritten to CHONKIE_DOCS_URL/assets/... so the
# unified site references the canonical chonkie static host.
# NEXT_PUBLIC_CHONKIE_DOCS_URL should match CHONKIE_DOCS_URL (used for nav logos).
#
# For local sync testing, build chonkie docs and serve the static export:
#   cd ../chonkie/docs && pnpm build && npx serve out -p 4321
# Then set both URLs to: http://localhost:4321
